<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pawan Trading Office | Premium Trading Solutions</title>
    <style>
        /* --- GLOBAL STYLES --- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #050505;
            color: #ffffff;
            overflow-x: hidden;
        }

        /* --- ANIMATED BACKGROUND (The "Video" Effect) --- */
        #canvas-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background: radial-gradient(circle at center, #1a1a2e 0%, #000000 100%);
        }

        /* --- HEADER & TITLE --- */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 50px;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(10px);
            position: fixed;
            width: 100%;
            z-index: 100;
            border-bottom: 2px solid #ffd700;
        }

        .logo {
            font-size: 2.5rem;
            font-weight: 900; /* EXTRA BOLD */
            color: #ffd700;
            text-transform: uppercase;
            letter-spacing: 3px;
            text-shadow: 0 0 20px rgba(255, 215, 0, 0.8);
        }

        .contact-btn {
            padding: 12px 30px;
            background: linear-gradient(45deg, #ffd700, #ffaa00);
            color: #000;
            font-weight: 800;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
        }

        .contact-btn:hover {
            transform: scale(1.1);
            box-shadow: 0 0 25px rgba(255, 215, 0, 0.8);
        }

        /* --- HERO SECTION --- */
        .hero {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 0 20px;
        }

        .hero h1 {
            font-size: 5rem;
            font-weight: 900; /* EXTRA BOLD */
            margin-bottom: 20px;
            background: linear-gradient(to right, #ffffff, #ffd700, #ffffff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: shine 3s infinite linear;
        }

        .hero p {
            font-size: 1.5rem;
            color: #ccc;
            margin-bottom: 40px;
            max-width: 800px;
            animation: fadeInUp 1.5s ease-out;
        }

        .scroll-down {
            position: absolute;
            bottom: 30px;
            animation: bounce 2s infinite;
            color: #ffd700;
            font-size: 2rem;
        }

        /* --- SERVICES SECTION --- */
        .services {
            padding: 100px 50px;
            position: relative;
        }

        .section-title {
            text-align: center;
            font-size: 3rem;
            margin-bottom: 60px;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 5px;
            font-weight: 800;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .card {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 40px;
            border-radius: 20px;
            text-align: center;
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(5px);
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, transparent, #ffd700, transparent);
            transform: translateX(-100%);
            transition: 0.5s;
        }

        .card:hover {
            transform: translateY(-15px);
            background: rgba(255, 255, 255, 0.1);
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6);
            border-color: #ffd700;
        }

        .card:hover::before {
            transform: translateX(100%);
        }

        .card h3 {
            font-size: 1.8rem;
            margin-bottom: 15px;
            color: #ffd700;
            font-weight: 800;
        }

        .card p {
            color: #aaa;
            line-height: 1.6;
        }

        .icon {
            font-size: 4rem;
            margin-bottom: 20px;
            display: block;
            filter: drop-shadow(0 0 10px rgba(255, 215, 0, 0.5));
        }

        /* --- CONTACT SECTION --- */
        .contact {
            background: linear-gradient(to top, #000, #111);
            padding: 100px 20px;
            text-align: center;
            border-top: 1px solid #333;
        }

        .contact-box {
            background: rgba(255, 215, 0, 0.1);
            display: inline-block;
            padding: 50px 80px;
            border-radius: 30px;
            border: 2px solid #ffd700;
            box-shadow: 0 0 50px rgba(255, 215, 0, 0.3);
            animation: pulse 3s infinite;
        }

        .contact h2 {
            font-size: 2.5rem;
            margin-bottom: 20px;
            font-weight: 800;
        }

        .phone-number {
            font-size: 3.5rem;
            font-weight: 900;
            color: #fff;
            display: block;
            margin: 20px 0;
            text-decoration: none;
            transition: color 0.3s;
        }

        .phone-number:hover {
            color: #ffd700;
        }

        .location {
            font-size: 1.5rem;
            color: #ffd700;
            margin-top: 10px;
            font-weight: 700;
        }

        /* --- ANIMATIONS --- */
        @keyframes shine {
            0% { background-position: 0% 50%; }
            100% { background-position: 100% 50%; }
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(50px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% {transform: translateY(0);}
            40% {transform: translateY(-10px);}
            60% {transform: translateY(-5px);}
        }

        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(255, 215, 0, 0.4); }
            70% { box-shadow: 0 0 0 20px rgba(255, 215, 0, 0); }
            100% { box-shadow: 0 0 0 0 rgba(255, 215, 0, 0); }
        }

        /* Mobile Adjustments */
        @media (max-width: 768px) {
            .hero h1 { font-size: 3rem; }
            .grid { grid-template-columns: 1fr; }
            header { padding: 15px 20px; }
            .logo { font-size: 1.5rem; }
            .contact-box { padding: 30px 20px; width: 90%; }
            .phone-number { font-size: 2rem; }
        }
    </style>
</head>
<body>

